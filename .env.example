# =============================================================================
# Supermarket Tracker — Environment Variable Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# The committed `.env.example` is the single source of truth for required keys.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Storage paths ---------------------------------------------------------
# SQLite database file (relative to project root). Auto-created on first run.
DATABASE_PATH=./data/super.db
# Directory for compressed product images uploaded from the browser.
UPLOAD_DIR=./uploads
# Hard cap on a single upload; the client also compresses to ~500KB before send.
MAX_UPLOAD_SIZE_MB=2

# --- VLM (MiniMax 國際板) configuration -----------------------------------
# 註冊並取得 API Key：https://platform.minimax.io
# 國際板 Base URL：https://api.minimax.io
# 端點：POST /v1/chat/completions（OpenAI 相容格式）
# 模型：MiniMax-M3（支援圖像與影片理解，限制 ≤ 10MB / JPEG/PNG/GIF/WEBP）
# 認證：Authorization: Bearer <API_KEY>（JWT 格式）
VLM_API_KEY=<your_minimax_api_key>
VLM_API_ENDPOINT=https://api.minimax.io/v1/chat/completions
VLM_MODEL=MiniMax-M3
# Per-request timeout (ms) for the VLM call; longer = better OCR on receipts.
VLM_TIMEOUT_MS=30000
# Maximum retry attempts when VLM returns malformed payloads.
VLM_MAX_RETRIES=2

# --- Exchange rate service -------------------------------------------------
# Free public endpoint; results are cached in SQLite for offline fallback.
EXCHANGE_API_ENDPOINT=https://api.exchangerate-api.com/v4/latest/USD
# How long a cached rate is considered fresh (hours).
EXCHANGE_FALLBACK_TTL_HOURS=24

# --- Webhook / workflow automation ----------------------------------------
# Outbound webhook delivery timeout (ms).
WEBHOOK_TIMEOUT_MS=5000
# Shared secret for signing outbound webhooks (HMAC-SHA256).
WEBHOOK_SIGNING_SECRET=<replace_with_random_32_byte_hex>
# Per-process rate limit for outbound webhook fan-out (requests / minute).
RATE_LIMIT_PER_MIN=60

# --- IP fingerprinting -----------------------------------------------------
# Random salt used to hash client IPs into stable but unlinkable fingerprints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_SALT=<random_string_for_fingerprint>

# --- Reverse proxy ---------------------------------------------------------
# When running behind Cloudflare Tunnel, set TRUSTED_PROXY=true so Express
# honours X-Forwarded-For for the real client IP (used for fingerprinting).
TRUSTED_PROXY=true

# --- Cloudflare Tunnel ----------------------------------------------------
# Token issued by `cloudflared tunnel login` + `create`. Keep it private.
CLOUDFLARE_TUNNEL_TOKEN=<your_token>
# Public hostname routed to the local app (matches the CNAME in Cloudflare DNS).
TUNNEL_HOSTNAME=sm.yuang093.cc
